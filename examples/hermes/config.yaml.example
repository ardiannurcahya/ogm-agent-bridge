mcp_servers:
  ogm:
    command: "uv"
    args:
      - "run"
      - "--project"
      - "/absolute/path/ogm-agent-bridge"
      - "ogm-agent-bridge"
    env:
      OGM_BASE_URL: "${OGM_BASE_URL}"
      OGM_API_KEY: "${OGM_API_KEY}"
      OGM_PROJECT_ID: "${OGM_PROJECT_ID}"
      OGM_PERMISSION_PROFILE: "${OGM_PERMISSION_PROFILE}"
    enabled: true
    timeout: 120
    connect_timeout: 60
    supports_parallel_tool_calls: false
    tools:
      resources: false
      prompts: false
