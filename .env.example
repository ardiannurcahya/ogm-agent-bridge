# OpenGraphMemory API connection
OGM_BASE_URL=http://localhost:8000
OGM_API_KEY=
OGM_PROJECT_ID=

# Request behavior
OGM_TIMEOUT_SECONDS=30
OGM_MAX_RETRIES=2

# Permission profile: read-only | personal-safe
OGM_PERMISSION_PROFILE=personal-safe

# Upload roots, separated by OS path separator. Default: resolved current directory.
# Linux/macOS example: OGM_UPLOAD_ROOTS=/srv/ogm-uploads:/tmp/approved
# Windows example: OGM_UPLOAD_ROOTS=C:\\approved;D:\\team-docs
