# OpenGraphMemory API connection
OGM_BASE_URL=http://localhost:8000
OGM_API_KEY=
OGM_PROJECT_ID=

# Request behavior
OGM_TIMEOUT_SECONDS=30
OGM_MAX_RETRIES=2

# Permission profile: personal-safe | read-only | full
OGM_PERMISSION_PROFILE=personal-safe

# Local bridge state (session mapping, provisioned identities)
OGM_STATE_DB=~/.local/share/ogm-agent-bridge/state.db
